<Application x:Class="SteamSwitcher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- 应用图标 - 矢量绘制 -->
        <DrawingGroup x:Key="AppIcon">
            <GeometryDrawing Brush="#0A84FF">
                <GeometryDrawing.Geometry>
                    <RectangleGeometry Rect="0,0,48,48" RadiusX="10" RadiusY="10"/>
                </GeometryDrawing.Geometry>
            </GeometryDrawing>
            <GeometryDrawing Brush="#1C1C1E">
                <GeometryDrawing.Geometry>
                    <RectangleGeometry Rect="4,4,40,40" RadiusX="7" RadiusY="7"/>
                </GeometryDrawing.Geometry>
            </GeometryDrawing>
            <GeometryDrawing Brush="White">
                <GeometryDrawing.Geometry>
                    <PathGeometry Figures="M16,14 L16,24 M24,14 L24,34 M32,24 L32,34 M12,14 L20,14 M20,34 L28,34 M28,24 L36,24"/>
                </GeometryDrawing.Geometry>
                <GeometryDrawing.Pen>
                    <Pen Brush="White" Thickness="3" StartLineCap="Round" EndLineCap="Round"/>
                </GeometryDrawing.Pen>
            </GeometryDrawing>
        </DrawingGroup>
    </Application.Resources>
</Application>
