<Application x:Class="SteamSwitcher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DrawingGroup x:Key="AppIcon">
                <GeometryDrawing Brush="#0A84FF">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,48,48" RadiusX="10" RadiusY="10"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#1C1C1E">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="4,4,40,40" RadiusX="7" RadiusY="7"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="White">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M16,14 L16,24 M24,14 L24,34 M32,24 L32,34 M12,14 L20,14 M20,34 L28,34 M28,24 L36,24"/>
                    </GeometryDrawing.Geometry>
                    <GeometryDrawing.Pen>
                        <Pen Brush="White" Thickness="3" StartLineCap="Round" EndLineCap="Round"/>
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingGroup>

            <!-- Dark theme defaults -->
            <SolidColorBrush x:Key="WindowBgBrush" Color="#FF0D0E15"/>
            <SolidColorBrush x:Key="CardBgBrush" Color="#0AFFFFFF"/>
            <SolidColorBrush x:Key="CardBgAltBrush" Color="#05FFFFFF"/>
            <SolidColorBrush x:Key="SidebarBgBrush" Color="#FF09090E"/>
            <SolidColorBrush x:Key="SidebarActiveBgBrush" Color="#1C007AFF"/>
            <SolidColorBrush x:Key="SidebarActiveFgBrush" Color="#FF007AFF"/>
            <SolidColorBrush x:Key="SidebarInactiveFgBrush" Color="#FF7D828F"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF9BA0B0"/>
            <SolidColorBrush x:Key="TextTertiaryBrush" Color="#FF5C606E"/>
            <SolidColorBrush x:Key="AccentBrush" Color="#FF007AFF"/>
            <SolidColorBrush x:Key="AccentBgBrush" Color="#14007AFF"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#1AFFFFFF"/>
            <SolidColorBrush x:Key="SeparatorBrush" Color="#10FFFFFF"/>
            <SolidColorBrush x:Key="InputBgBrush" Color="#0AFFFFFF"/>
            <SolidColorBrush x:Key="SearchPlaceholderFgBrush" Color="#FF585B66"/>
            <SolidColorBrush x:Key="SearchTextFgBrush" Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="HoverBgBrush" Color="#12FFFFFF"/>
            <SolidColorBrush x:Key="SelectedBgBrush" Color="#18007AFF"/>
            <SolidColorBrush x:Key="SelectedBgBrush2" Color="#24007AFF"/>
            <SolidColorBrush x:Key="SuccessBgBrush" Color="#1434C759"/>
            <SolidColorBrush x:Key="SuccessFgBrush" Color="#FF34C759"/>
            <SolidColorBrush x:Key="IconBgBrush" Color="#FF0C2540"/>
            <SolidColorBrush x:Key="AvatarBgBrush" Color="#FF1E1E24"/>
            <SolidColorBrush x:Key="ToggleBgBrush" Color="#FF0C0C0F"/>
            <SolidColorBrush x:Key="ToggleHoverBgBrush" Color="#FF1A2735"/>
            <SolidColorBrush x:Key="ToggleCheckedBgBrush" Color="#FF093D6B"/>
            <SolidColorBrush x:Key="BtnHoverBgBrush" Color="#1CFFFFFF"/>
            <SolidColorBrush x:Key="BtnDisabledBgBrush" Color="#FF0A0A0C"/>
            <SolidColorBrush x:Key="BtnDisabledFgBrush" Color="#44FFFFFF"/>
            <SolidColorBrush x:Key="ProgressBgBrush" Color="#FF222228"/>
            <SolidColorBrush x:Key="FooterTextBrush" Color="#FF222228"/>
            <SolidColorBrush x:Key="FooterLinkBrush" Color="#FF2A2A30"/>
            <SolidColorBrush x:Key="BtnSecondaryFgBrush" Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="ToggleTrackBgBrush" Color="#1CFFFFFF"/>
            <SolidColorBrush x:Key="ToggleTrackBorderBrush" Color="#24FFFFFF"/>
            <SolidColorBrush x:Key="ToggleThumbBrush" Color="#FFF0F0F0"/>
            <SolidColorBrush x:Key="ToggleTrackCheckedBgBrush" Color="#66007AFF"/>
            <SolidColorBrush x:Key="ToggleTrackCheckedBorderBrush" Color="#92BBDDFF"/>
            <SolidColorBrush x:Key="ScrollThumbBrush" Color="#2CFFFFFF"/>
            <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#4CFFFFFF"/>
            <SolidColorBrush x:Key="ScrollThumbDragBrush" Color="#6CFFFFFF"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
