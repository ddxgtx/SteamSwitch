<Application x:Class="SteamSwitcher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <DrawingGroup x:Key="AppIcon">
                <GeometryDrawing Brush="#0A84FF">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,48,48" RadiusX="10" RadiusY="10"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="#1C1C1E">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="4,4,40,40" RadiusX="7" RadiusY="7"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing Brush="White">
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M16,14 L16,24 M24,14 L24,34 M32,24 L32,34 M12,14 L20,14 M20,34 L28,34 M28,24 L36,24"/>
                    </GeometryDrawing.Geometry>
                    <GeometryDrawing.Pen>
                        <Pen Brush="White" Thickness="3" StartLineCap="Round" EndLineCap="Round"/>
                    </GeometryDrawing.Pen>
                </GeometryDrawing>
            </DrawingGroup>

            <!-- Dark theme defaults -->
            <SolidColorBrush x:Key="WindowBgBrush" Color="#FF19191C"/>
            <SolidColorBrush x:Key="CardBgBrush" Color="#1EFFFFFF"/>
            <SolidColorBrush x:Key="CardBgAltBrush" Color="#14FFFFFF"/>
            <SolidColorBrush x:Key="SidebarBgBrush" Color="#FF19191C"/>
            <SolidColorBrush x:Key="SidebarActiveBgBrush" Color="#1A0A84FF"/>
            <SolidColorBrush x:Key="SidebarActiveFgBrush" Color="#FF0A84FF"/>
            <SolidColorBrush x:Key="SidebarInactiveFgBrush" Color="#FF8E8E96"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF8E8E96"/>
            <SolidColorBrush x:Key="TextTertiaryBrush" Color="#FF6C6C72"/>
            <SolidColorBrush x:Key="AccentBrush" Color="#FF0A84FF"/>
            <SolidColorBrush x:Key="AccentBgBrush" Color="#1A0A84FF"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#FF2C2C2E"/>
            <SolidColorBrush x:Key="SeparatorBrush" Color="#22FFFFFF"/>
            <SolidColorBrush x:Key="InputBgBrush" Color="#14FFFFFF"/>
            <SolidColorBrush x:Key="SearchPlaceholderFgBrush" Color="#FF636366"/>
            <SolidColorBrush x:Key="SearchTextFgBrush" Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="HoverBgBrush" Color="#1AFFFFFF"/>
            <SolidColorBrush x:Key="SelectedBgBrush" Color="#1A0A84FF"/>
            <SolidColorBrush x:Key="SelectedBgBrush2" Color="#220A84FF"/>
            <SolidColorBrush x:Key="SuccessBgBrush" Color="#1E30D158"/>
            <SolidColorBrush x:Key="SuccessFgBrush" Color="#FF30D158"/>
            <SolidColorBrush x:Key="IconBgBrush" Color="#FF182C45"/>
            <SolidColorBrush x:Key="AvatarBgBrush" Color="#FF3A3A3C"/>
            <SolidColorBrush x:Key="ToggleBgBrush" Color="#FF17171B"/>
            <SolidColorBrush x:Key="ToggleHoverBgBrush" Color="#FF2F3D4A"/>
            <SolidColorBrush x:Key="ToggleCheckedBgBrush" Color="#FF1A3D5F"/>
            <SolidColorBrush x:Key="BtnHoverBgBrush" Color="#FF2C2C2E"/>
            <SolidColorBrush x:Key="BtnDisabledBgBrush" Color="#FF111111"/>
            <SolidColorBrush x:Key="BtnDisabledFgBrush" Color="#55FFFFFF"/>
            <SolidColorBrush x:Key="ProgressBgBrush" Color="#FF38383A"/>
            <SolidColorBrush x:Key="FooterTextBrush" Color="#FF38383A"/>
            <SolidColorBrush x:Key="FooterLinkBrush" Color="#FF48484A"/>
            <SolidColorBrush x:Key="BtnSecondaryFgBrush" Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="ToggleTrackBgBrush" Color="#26FFFFFF"/>
            <SolidColorBrush x:Key="ToggleTrackBorderBrush" Color="#34FFFFFF"/>
            <SolidColorBrush x:Key="ToggleThumbBrush" Color="#FFF6F6F6"/>
            <SolidColorBrush x:Key="ToggleTrackCheckedBgBrush" Color="#660A84FF"/>
            <SolidColorBrush x:Key="ToggleTrackCheckedBorderBrush" Color="#92CFE8FF"/>
            <SolidColorBrush x:Key="ScrollThumbBrush" Color="#44FFFFFF"/>
            <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#66FFFFFF"/>
            <SolidColorBrush x:Key="ScrollThumbDragBrush" Color="#8898989D"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
