<Window x:Class="SteamSwitcher.Views.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="发现新版本"
        Width="480" Height="420"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="{DynamicResource WindowBgBrush}" CornerRadius="16" Padding="20"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="发现新版本" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="18" FontWeight="Bold"/>
                    <TextBlock x:Name="VersionText" Text="v0.0.0" Foreground="{DynamicResource AccentBrush}" FontSize="14" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="×" Width="28" Height="28" Click="Close_Click"
                        Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}"
                        BorderThickness="0" FontSize="16" Cursor="Hand" VerticalAlignment="Top"/>
            </Grid>

            <TextBlock Grid.Row="1" x:Name="CurrentVersionText" Text="当前版本：v0.0.0"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,10"/>

            <Border Grid.Row="2" Background="{DynamicResource CardBgBrush}" CornerRadius="8" Padding="12"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="ChangelogText" Text="正在加载..."
                               Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"
                               TextWrapping="Wrap" LineHeight="20"/>
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="3" x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,0,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="DownloadStatusText" Text="正在下载..." Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                    <TextBlock Grid.Column="1" x:Name="DownloadPercentText" Text="0%"
                               Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="SemiBold"/>
                </Grid>
                <ProgressBar Grid.Row="1" x:Name="DownloadProgressBar" Height="6" Margin="0,6,0,0"
                             Minimum="0" Maximum="100" Value="0" Foreground="{DynamicResource AccentBrush}"
                             Background="{DynamicResource CardBgBrush}"/>
            </Grid>

            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="IgnoreButton" Content="稍后提醒" Width="90" Height="34" Click="Ignore_Click"
                        Style="{StaticResource SecondaryButtonStyle}" FontSize="12" Margin="0,0,10,0"/>
                <Button x:Name="DownloadButton" Content="立即更新" Width="90" Height="34" Click="Download_Click"
                        Style="{StaticResource PrimaryButtonStyle}" FontSize="12"/>
                <Button x:Name="CancelButton" Content="取消下载" Width="90" Height="34" Click="Cancel_Click"
                        Style="{StaticResource SecondaryButtonStyle}" FontSize="12" Visibility="Collapsed"/>
                <Button x:Name="InstallButton" Content="立即安装" Width="90" Height="34" Click="Install_Click"
                        Style="{StaticResource PrimaryButtonStyle}" FontSize="12" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
