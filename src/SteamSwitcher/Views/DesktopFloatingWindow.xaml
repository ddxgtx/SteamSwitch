<Window x:Class="SteamSwitcher.Views.DesktopFloatingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam Switch Floating"
        Width="320" Height="78"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border x:Name="RootGlass"
            CornerRadius="20"
            Padding="2"
            BorderThickness="1"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="#5B9BFF" BlurRadius="18" ShadowDepth="0" Opacity="0.22"/>
        </Border.Effect>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#8DFFFFFF" Offset="0"/>
                <GradientStop Color="#42EAF6FF" Offset="0.48"/>
                <GradientStop Color="#35BFDFFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid ClipToBounds="True">
            <Border CornerRadius="18">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#78FFFFFF" Offset="0"/>
                        <GradientStop Color="#30FFFFFF" Offset="0.52"/>
                        <GradientStop Color="#42E7F8FF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border Height="1" VerticalAlignment="Top" Margin="18,2"
                    Background="#F0FFFFFF" Opacity="0.82"/>
            <Border Width="44" HorizontalAlignment="Left" Margin="10,4,0,4"
                    CornerRadius="16" Opacity="0.34">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#DCFFFFFF" Offset="0"/>
                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <DockPanel Margin="8,6" LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Width="96" VerticalAlignment="Center" Margin="4,0,8,0">
                    <TextBlock Text="Steam Switch" Foreground="#F5FFFFFF" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock x:Name="HintText" Text="桌面悬浮" Foreground="#B8FFFFFF" FontSize="10" Margin="0,3,0,0"/>
                </StackPanel>
                <Border DockPanel.Dock="Left" Width="1" Margin="0,7,9,7" Background="#7EFFFFFF"/>
                <StackPanel DockPanel.Dock="Right" x:Name="AvatarPanel" Orientation="Horizontal" VerticalAlignment="Center"/>
                <Border DockPanel.Dock="Right"
                        x:Name="GameAvatarSeparator"
                        Width="1" Margin="8,8"
                        Background="#8EFFFFFF"
                        Visibility="Collapsed"/>
                <StackPanel DockPanel.Dock="Right" x:Name="GamePanel" Orientation="Horizontal" VerticalAlignment="Center"/>
            </DockPanel>
        </Grid>
    </Border>
</Window>
