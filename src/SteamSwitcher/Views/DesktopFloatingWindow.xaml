<Window x:Class="SteamSwitcher.Views.DesktopFloatingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam Switch Floating"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseRightButtonDown="Window_MouseRightButtonDown">

    <Grid>
        <Border x:Name="RootGlass"
                CornerRadius="20"
                Padding="6,5"
                BorderThickness="1"
                BorderBrush="#3FFFFFFF">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="25" ShadowDepth="2" Opacity="0.2"/>
            </Border.Effect>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#26FFFFFF" Offset="0"/>
                    <GradientStop Color="#0FFFFFFF" Offset="0.5"/>
                    <GradientStop Color="#1AFFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <DockPanel Margin="6,4" LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Width="90" VerticalAlignment="Center" Margin="2,0,6,0">
                    <TextBlock Text="Steam Switch" Foreground="#F0FFFFFF" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock x:Name="HintText" Text="桌面悬浮" Foreground="#B0FFFFFF" FontSize="10" Margin="0,2,0,0"/>
                </StackPanel>
                <Border DockPanel.Dock="Left" Width="1" Margin="0,6,7,6" Background="#60FFFFFF"/>
                <StackPanel DockPanel.Dock="Right" x:Name="AvatarPanel" Orientation="Horizontal" VerticalAlignment="Center"/>
                <Border DockPanel.Dock="Right"
                        x:Name="GameAvatarSeparator"
                        Width="1" Margin="6,8"
                        Background="#60FFFFFF"
                        Visibility="Collapsed"/>
                <StackPanel DockPanel.Dock="Right" x:Name="GamePanel" Orientation="Horizontal" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
