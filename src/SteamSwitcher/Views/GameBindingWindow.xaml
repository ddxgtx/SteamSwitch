<Window x:Class="SteamSwitcher.Views.GameBindingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="游戏账号绑定"
        Height="450" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="#1C1C1E"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Window.Resources>
        <Style x:Key="BtnClose" TargetType="Button">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#98989D"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" x:Name="bg">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AddBtn" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#0A84FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" x:Name="b">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#409CFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="BindingItemTemplate">
            <Border Background="#2C2C2E" CornerRadius="8" Padding="12" Margin="0,2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding GameName}" Foreground="White" FontSize="14" FontWeight="Medium"/>
                        <TextBlock Foreground="#636366" FontSize="11" Margin="0,4,0,0">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="AppID: {0} | 账号: {1}">
                                    <Binding Path="AppId"/>
                                    <Binding Path="AccountName"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Foreground="#48484A" FontSize="10" Margin="0,2,0,0">
                            <Run Text="上次游玩: "/>
                            <Run Text="{Binding LastPlayed}"/>
                        </TextBlock>
                    </StackPanel>

                    <CheckBox Grid.Column="1" Content="自动切换" 
                              IsChecked="{Binding AutoSwitch}" 
                              Foreground="#98989D" FontSize="11"
                              VerticalAlignment="Center" Margin="0,0,12,0"/>

                    <Button Grid.Column="2" Content="✕" 
                            Tag="{Binding AppId}"
                            Click="RemoveBinding_Click"
                            Width="24" Height="24"
                            Background="Transparent" Foreground="#636366"
                            BorderThickness="0" Cursor="Hand"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>
    
    <Border Background="#1C1C1E" CornerRadius="10" BorderBrush="#2C2C2E" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="#1C1C1E" CornerRadius="10,10,0,0">
                <Grid Height="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="🎮 游戏账号绑定" FontSize="15" FontWeight="SemiBold" 
                               Foreground="White" VerticalAlignment="Center" Margin="16,0,0,0"/>

                    <Button Grid.Column="1" Content="✕" 
                            Style="{StaticResource BtnClose}" Click="Close_Click" Margin="0,0,8,0"/>
                </Grid>
            </Border>

            <Border Grid.Row="0" Height="0.5" VerticalAlignment="Bottom" Background="#2C2C2E"/>

            <!-- 绑定列表 -->
            <ListBox Grid.Row="1" ItemsSource="{Binding GameBindings}"
                     ItemTemplate="{StaticResource BindingItemTemplate}"
                     Background="Transparent" BorderThickness="0"
                     Margin="8,8,8,0">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- 添加绑定 -->
            <Border Grid.Row="2" Background="#2C2C2E" CornerRadius="8" Margin="8,8,8,8" Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="AppID:" Foreground="#98989D" 
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="1" x:Name="AppIdInput" 
                             Background="#1C1C1E" Foreground="White" 
                             BorderBrush="#48484A" BorderThickness="1"
                             Padding="6,4" Margin="0,0,12,0"/>

                    <TextBlock Grid.Column="2" Text="游戏名:" Foreground="#98989D" 
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="3" x:Name="GameNameInput" 
                             Background="#1C1C1E" Foreground="White" 
                             BorderBrush="#48484A" BorderThickness="1"
                             Padding="6,4" Margin="0,0,12,0"/>

                    <Button Grid.Column="4" Content="添加" 
                            Style="{StaticResource AddBtn}" Width="60"
                            Click="AddBinding_Click"/>
                </Grid>
            </Border>

            <!-- 底部 -->
            <Border Grid.Row="3" Background="#19FFFFFF" CornerRadius="0,0,10,10" Padding="16,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="关闭" Width="80" Click="Close_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Height" Value="30"/>
                                <Setter Property="Background" Value="#3A3A3C"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="6" x:Name="b">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="b" Property="Background" Value="#4A4A4C"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
