<Window x:Class="SteamSwitcher.Views.TaskbarBandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam Switch Taskbar"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Grid>
        <Border x:Name="GlassBorder"
                Background="Transparent"
                BorderThickness="1"
                ClipToBounds="True">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="1" Opacity="0.15"/>
            </Border.Effect>

            <DockPanel x:Name="ContentPanel" LastChildFill="False">
                <StackPanel DockPanel.Dock="Right" x:Name="AvatarPanel" Orientation="Horizontal"/>
                <Border DockPanel.Dock="Right"
                        x:Name="GameAvatarSeparator"
                        Width="1" Margin="4,6"
                        Background="#60FFFFFF"
                        Visibility="Collapsed"/>
                <StackPanel DockPanel.Dock="Right" x:Name="GamePanel" Orientation="Horizontal"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
