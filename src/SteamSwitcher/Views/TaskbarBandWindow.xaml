<Window x:Class="SteamSwitcher.Views.TaskbarBandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam Switch Taskbar"
        Height="46" Width="166"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Manual"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    
    <Border x:Name="GlassBorder"
            CornerRadius="16"
            Padding="2"
            BorderThickness="1"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="#6AA8FF" BlurRadius="14" ShadowDepth="0" Opacity="0.20"/>
        </Border.Effect>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#88FFFFFF" Offset="0"/>
                <GradientStop Color="#42EAF6FF" Offset="0.44"/>
                <GradientStop Color="#2FD3E6FF" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid ClipToBounds="True">
            <Border CornerRadius="13">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#70FFFFFF" Offset="0"/>
                        <GradientStop Color="#28FFFFFF" Offset="0.50"/>
                        <GradientStop Color="#42E8F8FF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border Height="1" VerticalAlignment="Top" Margin="12,1"
                    Background="#E8FFFFFF" Opacity="0.78"/>
            <Border Width="34" HorizontalAlignment="Left" Margin="9,3,0,3"
                    CornerRadius="13" Opacity="0.38">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#D8FFFFFF" Offset="0"/>
                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border Height="1" VerticalAlignment="Bottom" Margin="16,0,16,1"
                    Background="#58A9C8FF" Opacity="0.45"/>
            <DockPanel Margin="5,1" LastChildFill="False">
                <StackPanel DockPanel.Dock="Right" x:Name="AvatarPanel" Orientation="Horizontal"/>
                <Border DockPanel.Dock="Right"
                        x:Name="GameAvatarSeparator" 
                        Width="1" Margin="7,8" 
                        Background="#8EFFFFFF"
                        Visibility="Collapsed"/>
                <StackPanel DockPanel.Dock="Right" x:Name="GamePanel" Orientation="Horizontal"/>
            </DockPanel>
        </Grid>
    </Border>
</Window>
