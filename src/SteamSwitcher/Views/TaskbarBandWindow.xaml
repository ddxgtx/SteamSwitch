<Window x:Class="SteamSwitcher.Views.TaskbarBandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam Switch Taskbar"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Border x:Name="GlassBorder"
            BorderThickness="1"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="#4A90D9" BlurRadius="12" ShadowDepth="0" Opacity="0.18"/>
        </Border.Effect>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#99FFFFFF" Offset="0"/>
                <GradientStop Color="#55E8F4FF" Offset="0.5"/>
                <GradientStop Color="#44D0EAFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <DockPanel x:Name="ContentPanel" LastChildFill="False">
            <StackPanel DockPanel.Dock="Right" x:Name="AvatarPanel" Orientation="Horizontal"/>
            <Border DockPanel.Dock="Right"
                    x:Name="GameAvatarSeparator"
                    Width="1" Margin="4,6"
                    Background="#60FFFFFF"
                    Visibility="Collapsed"/>
            <StackPanel DockPanel.Dock="Right" x:Name="GamePanel" Orientation="Horizontal"/>
        </DockPanel>
    </Border>
</Window>
