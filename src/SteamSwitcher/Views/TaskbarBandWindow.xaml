<Window x:Class="SteamSwitcher.Views.TaskbarBandWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam Switch Taskbar"
        Height="44" Width="200"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">
    
    <Border x:Name="GlassBorder" CornerRadius="8" Padding="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#30FFFFFF" Offset="0"/>
                <GradientStop Color="#18FFFFFF" Offset="0.5"/>
                <GradientStop Color="#08FFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border CornerRadius="7">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#10FFFFFF" Offset="0"/>
                    <GradientStop Color="#05FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal" Margin="3,2" x:Name="AvatarPanel">
                <!-- 头像会动态添加到这里 -->
            </StackPanel>
        </Border>
    </Border>
</Window>
