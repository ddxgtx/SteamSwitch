                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                            <StackPanel>
                                                <Border Padding="14,12" Style="{StaticResource SettingRowStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="启用任务栏常驻" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="把固定账号和固定游戏嵌入 Windows 任务栏" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                        <CheckBox Grid.Column="1" IsChecked="{Binding IsTaskbarPinned}" Checked="TaskbarPin_Checked" Unchecked="TaskbarPin_Unchecked" Style="{StaticResource SwitchToggle}" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                                <Border Background="{DynamicResource SeparatorBrush}" Height="0.5" Margin="14,0"/>
                                                <Border Padding="14,12" Style="{StaticResource SettingRowStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="88"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Text="位置" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <RadioButton x:Name="SettingsPosAuto" Content="自动" GroupName="InlineTaskbarPos" Checked="SettingsPos_Changed" Tag="Auto" Margin="0,0,12,0" Style="{StaticResource SettingsRadio}"/>
                                                            <RadioButton x:Name="SettingsPosLeft" Content="左" GroupName="InlineTaskbarPos" Checked="SettingsPos_Changed" Tag="Left" Margin="0,0,12,0" Style="{StaticResource SettingsRadio}"/>
                                                            <RadioButton x:Name="SettingsPosCenter" Content="中" GroupName="InlineTaskbarPos" Checked="SettingsPos_Changed" Tag="Center" Margin="0,0,12,0" Style="{StaticResource SettingsRadio}"/>
                                                            <RadioButton x:Name="SettingsPosRight" Content="右" GroupName="InlineTaskbarPos" Checked="SettingsPos_Changed" Tag="Right" Style="{StaticResource SettingsRadio}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <Border Background="{DynamicResource SeparatorBrush}" Height="0.5" Margin="14,0"/>
                                                <Border Padding="14,12" Style="{StaticResource SettingRowStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="88"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Text="X轴偏移" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        <DockPanel Grid.Column="1">
                                                            <TextBlock x:Name="SettingsOffsetXText" Text="0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="SemiBold" Width="42" TextAlignment="Right" VerticalAlignment="Center" DockPanel.Dock="Right"/>
                                                            <Slider x:Name="SettingsOffsetXSlider" Minimum="-200" Maximum="200" Value="0" TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="SettingsOffsetX_ValueChanged" VerticalAlignment="Center"/>
                                                        </DockPanel>
                                                    </Grid>
                                                </Border>
                                                <Border Background="{DynamicResource SeparatorBrush}" Height="0.5" Margin="14,0"/>
                                                <Border Padding="14,12" Style="{StaticResource SettingRowStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="88"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Text="Y轴偏移" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        <DockPanel Grid.Column="1">
                                                            <TextBlock x:Name="SettingsOffsetYText" Text="0" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="SemiBold" Width="42" TextAlignment="Right" VerticalAlignment="Center" DockPanel.Dock="Right"/>
                                                            <Slider x:Name="SettingsOffsetYSlider" Minimum="-200" Maximum="200" Value="0" TickFrequency="10" IsSnapToTickEnabled="True" ValueChanged="SettingsOffsetY_ValueChanged" VerticalAlignment="Center"/>
                                                        </DockPanel>
                                                    </Grid>
                                                </Border>
                                                <Border Background="{DynamicResource SeparatorBrush}" Height="0.5" Margin="14,0"/>
                                                <Border Padding="14,12" Style="{StaticResource SettingRowStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="88"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Text="图标大小" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        <DockPanel Grid.Column="1">
                                                            <TextBlock x:Name="SettingsTaskbarAvatarText" Text="38" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="SemiBold" Width="42" TextAlignment="Right" VerticalAlignment="Center" DockPanel.Dock="Right"/>
                                                            <Slider x:Name="SettingsTaskbarAvatarSlider" Minimum="16" Maximum="40" Value="38" TickFrequency="2" IsSnapToTickEnabled="True" ValueChanged="SettingsTaskbarAvatar_ValueChanged" VerticalAlignment="Center"/>
                                                        </DockPanel>
                                                    </Grid>
                                                </Border>
                                                <Border Background="{DynamicResource SeparatorBrush}" Height="0.5" Margin="14,0"/>
                                                <Border Padding="14,12" Style="{StaticResource SettingRowStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="任务栏毛玻璃" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="任务栏使用半透明玻璃背景" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                        <CheckBox Grid.Column="1" IsChecked="{Binding TaskbarGlassEnabled}" Checked="SettingsTaskbarGlass_Changed" Unchecked="SettingsTaskbarGlass_Changed" Style="{StaticResource SwitchToggle}" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                                <Border Background="{DynamicResource SeparatorBrush}" Height="0.5" Margin="14,0"/>
                                                <Border Padding="14,12" Style="{StaticResource SettingRowStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="圆形模式" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="启用后账号头像呈圆形显示，游戏图标呈圆角显示" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                        <CheckBox Grid.Column="1" IsChecked="{Binding TaskbarRoundedMode}" Checked="SettingsTaskbarRounded_Changed" Unchecked="SettingsTaskbarRounded_Changed" Style="{StaticResource SwitchToggle}" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Border>
 
                                        <!-- 桌面悬浮窗 -->
                                        <StackPanel Orientation="Horizontal" Margin="14,8,14,8">
                                            <Border Height="12" Width="3" CornerRadius="1.5" Background="{DynamicResource AccentBrush}"/>
                                            <TextBlock Text="桌面悬浮窗" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="14" Margin="6,0,6,10" Padding="0"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                            <StackPanel>
                                                <Border Padding="14,12" Style="{StaticResource SettingRowStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="启用桌面悬浮窗" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="在桌面显示可拖动的固定账号和固定游戏快捷入口" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                        <CheckBox Grid.Column="1" IsChecked="{Binding DesktopFloatingEnabled}" Checked="DesktopFloating_Checked" Unchecked="DesktopFloating_Unchecked" Style="{StaticResource SwitchToggle}" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                                <Border Background="{DynamicResource SeparatorBrush}" Height="0.5" Margin="14,0"/>
                                                <Border Padding="14,12" Style="{StaticResource SettingRowStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="始终置顶" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="让悬浮窗保持在其他窗口上方" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                        <CheckBox Grid.Column="1" IsChecked="{Binding DesktopFloatingTopmost}" Checked="SettingsFloatingTopmost_Changed" Unchecked="SettingsFloatingTopmost_Changed" Style="{StaticResource SwitchToggle}" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                                <Border Background="{DynamicResource SeparatorBrush}" Height="0.5" Margin="14,0"/>
                                                <Border Padding="14,12" Style="{StaticResource SettingRowStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="锁定位置" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="防止误拖动，关闭后可拖动悬浮窗并保存位置" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                        <CheckBox Grid.Column="1" IsChecked="{Binding DesktopFloatingLocked}" Checked="SettingsFloatingLocked_Changed" Unchecked="SettingsFloatingLocked_Changed" Style="{StaticResource SwitchToggle}" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                                <Border Background="{DynamicResource SeparatorBrush}" Height="0.5" Margin="14,0"/>
                                                <Border Padding="14,12" Style="{StaticResource SettingRowStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="88"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Text="透明度" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        <DockPanel Grid.Column="1">
                                                            <TextBlock x:Name="SettingsFloatingOpacityText" Text="80%" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="SemiBold" Width="42" TextAlignment="Right" VerticalAlignment="Center" DockPanel.Dock="Right"/>
                                                            <Slider x:Name="SettingsFloatingOpacitySlider" Minimum="20" Maximum="100" Value="80" TickFrequency="5" IsSnapToTickEnabled="True" ValueChanged="SettingsFloatingOpacity_ValueChanged" VerticalAlignment="Center"/>
                                                        </DockPanel>
                                                    </Grid>
                                                </Border>
                                                <Border Background="{DynamicResource SeparatorBrush}" Height="0.5" Margin="14,0"/>
                                                <Border Padding="14,12" Style="{StaticResource SettingRowStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="88"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Text="图标大小" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        <DockPanel Grid.Column="1">
                                                            <TextBlock x:Name="SettingsFloatingAvatarText" Text="45" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" FontWeight="SemiBold" Width="42" TextAlignment="Right" VerticalAlignment="Center" DockPanel.Dock="Right"/>
                                                            <Slider x:Name="SettingsFloatingAvatarSlider" Minimum="24" Maximum="72" Value="45" TickFrequency="2" IsSnapToTickEnabled="True" ValueChanged="SettingsFloatingAvatar_ValueChanged" VerticalAlignment="Center"/>
                                                        </DockPanel>
                                                    </Grid>
                                                </Border>
                                                <Border Background="{DynamicResource SeparatorBrush}" Height="0.5" Margin="14,0"/>
                                                <Border Padding="14,12" Style="{StaticResource SettingRowStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="悬浮窗毛玻璃" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="悬浮窗使用半透明玻璃背景" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                        <CheckBox Grid.Column="1" IsChecked="{Binding DesktopFloatingGlassEnabled}" Checked="SettingsFloatingGlass_Changed" Unchecked="SettingsFloatingGlass_Changed" Style="{StaticResource SwitchToggle}" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                                <Border Background="{DynamicResource SeparatorBrush}" Height="0.5" Margin="14,0"/>
                                                <Border Padding="14,12" Style="{StaticResource SettingRowStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="圆形模式" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="启用后账号头像呈圆形显示，游戏图标呈圆角显示" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                        <CheckBox Grid.Column="1" IsChecked="{Binding DesktopFloatingRoundedMode}" Checked="SettingsFloatingRounded_Changed" Unchecked="SettingsFloatingRounded_Changed" Style="{StaticResource SwitchToggle}" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                                <Border Background="{DynamicResource SeparatorBrush}" Height="0.5" Margin="14,0"/>
                                                <Border Padding="14,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="玻璃颜色" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="自选液态玻璃效果的主色调" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Border Tag="#4A90D9" ToolTip="蓝色" MouseLeftButtonDown="GlassColor_Click">
                                                                <Border.Background><SolidColorBrush Color="#4A90D9"/></Border.Background>
                                                                <Border.Style><Style TargetType="Border" BasedOn="{StaticResource ColorBlockStyle}"><Setter Property="BorderBrush" Value="Transparent"/><Style.Triggers><DataTrigger Binding="{Binding DesktopFloatingGlassColor}" Value="#4A90D9"><Setter Property="BorderBrush" Value="White"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                                            </Border>
                                                            <Border Tag="#9B59B6" ToolTip="紫色" MouseLeftButtonDown="GlassColor_Click">
                                                                <Border.Background><SolidColorBrush Color="#9B59B6"/></Border.Background>
                                                                <Border.Style><Style TargetType="Border" BasedOn="{StaticResource ColorBlockStyle}"><Setter Property="BorderBrush" Value="Transparent"/><Style.Triggers><DataTrigger Binding="{Binding DesktopFloatingGlassColor}" Value="#9B59B6"><Setter Property="BorderBrush" Value="White"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                                            </Border>
                                                            <Border Tag="#30D158" ToolTip="绿色" MouseLeftButtonDown="GlassColor_Click">
                                                                <Border.Background><SolidColorBrush Color="#30D158"/></Border.Background>
                                                                <Border.Style><Style TargetType="Border" BasedOn="{StaticResource ColorBlockStyle}"><Setter Property="BorderBrush" Value="Transparent"/><Style.Triggers><DataTrigger Binding="{Binding DesktopFloatingGlassColor}" Value="#30D158"><Setter Property="BorderBrush" Value="White"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                                            </Border>
                                                            <Border Tag="#FF9F0A" ToolTip="橙色" MouseLeftButtonDown="GlassColor_Click">
                                                                <Border.Background><SolidColorBrush Color="#FF9F0A"/></Border.Background>
                                                                <Border.Style><Style TargetType="Border" BasedOn="{StaticResource ColorBlockStyle}"><Setter Property="BorderBrush" Value="Transparent"/><Style.Triggers><DataTrigger Binding="{Binding DesktopFloatingGlassColor}" Value="#FF9F0A"><Setter Property="BorderBrush" Value="White"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                                            </Border>
                                                            <Border Tag="#FF453A" ToolTip="红色" MouseLeftButtonDown="GlassColor_Click">
                                                                <Border.Background><SolidColorBrush Color="#FF453A"/></Border.Background>
                                                                <Border.Style><Style TargetType="Border" BasedOn="{StaticResource ColorBlockStyle}"><Setter Property="BorderBrush" Value="Transparent"/><Style.Triggers><DataTrigger Binding="{Binding DesktopFloatingGlassColor}" Value="#FF453A"><Setter Property="BorderBrush" Value="White"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                                            </Border>
                                                            <Border Tag="#FF6B9D" ToolTip="粉色" MouseLeftButtonDown="GlassColor_Click">
                                                                <Border.Background><SolidColorBrush Color="#FF6B9D"/></Border.Background>
                                                                <Border.Style><Style TargetType="Border" BasedOn="{StaticResource ColorBlockStyle}"><Setter Property="BorderBrush" Value="Transparent"/><Style.Triggers><DataTrigger Binding="{Binding DesktopFloatingGlassColor}" Value="#FF6B9D"><Setter Property="BorderBrush" Value="White"/></DataTrigger></Style.Triggers></Style></Border.Style>
                                                            </Border>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

            <!-- 底部栏 -->
            <Border Grid.Row="2" Background="{DynamicResource CardBgAltBrush}" Padding="14,10">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="切换并启动 Steam" Command="{Binding SwitchAndLaunchCommand}"
                                IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}"
                                Style="{StaticResource PrimaryBtn}" Margin="0,0,6,0"/>
                        <Button Grid.Column="1" Content="仅切换账号" Command="{Binding SwitchOnlyCommand}"
                                IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}"
                                Style="{StaticResource SecondaryBtn}" Margin="6,0,0,0"/>
                    </Grid>

                    <WrapPanel Margin="0,0,0,6">
                        <CheckBox Content="启动Steam" IsChecked="{Binding AutoStartSteam}" Checked="SettingsAutoStartSteam_Changed" Unchecked="SettingsAutoStartSteam_Changed" Style="{StaticResource AppCheckBox}"/>
                        <CheckBox Content="静默模式" IsChecked="{Binding SilentCloseSteam}" Checked="SettingsSilentCloseSteam_Changed" Unchecked="SettingsSilentCloseSteam_Changed" Style="{StaticResource AppCheckBox}" Margin="14,0,0,0"/>
                        <CheckBox Content="最小化到托盘" IsChecked="{Binding MinimizeToTray}" Checked="SettingsMinimizeToTray_Changed" Unchecked="SettingsMinimizeToTray_Changed" Style="{StaticResource AppCheckBox}" Margin="14,0,0,0"/>
                        <CheckBox Content="任务栏常驻" IsChecked="{Binding IsTaskbarPinned}" Checked="TaskbarPin_Checked" Unchecked="TaskbarPin_Unchecked" Style="{StaticResource AppCheckBox}" Margin="14,0,0,0"/>
                        <CheckBox Content="桌面悬浮窗" IsChecked="{Binding DesktopFloatingEnabled}" Checked="DesktopFloating_Checked" Unchecked="DesktopFloating_Unchecked" Style="{StaticResource AppCheckBox}" Margin="14,0,0,0"/>
                        <CheckBox Content="库界面注入 ⚠️" IsChecked="{Binding EnableLibraryInjection}" Checked="SettingsLibraryInjection_Changed" Unchecked="SettingsLibraryInjection_Changed" Style="{StaticResource AppCheckBox}" Margin="14,0,0,0"/>
                    </WrapPanel>

                    <Border Background="{DynamicResource InputBgBrush}" CornerRadius="8" Padding="10,6" Margin="0,0,0,6">
                        <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    </Border>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Powered by " Foreground="{DynamicResource FooterTextBrush}" FontSize="10"/>
                        <TextBlock Text="ddxgtx" Foreground="{DynamicResource FooterLinkBrush}" FontSize="10" FontWeight="Medium"/>
                        <TextBlock Text="  |  " Foreground="{DynamicResource FooterTextBrush}" FontSize="10"/>
                        <TextBlock Text="GitHub" Foreground="{DynamicResource AccentBrush}" FontSize="10" Cursor="Hand" MouseLeftButtonDown="GitHubLink_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 加载遮罩 - 覆盖全窗口 -->
            <Border Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" Background="{DynamicResource WindowBgBrush}" Opacity="0.92" Grid.RowSpan="3">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="120" Height="3" Foreground="{DynamicResource AccentBrush}" Background="{DynamicResource ProgressBgBrush}"/>
                    <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,16,0,0" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- 调整大小手柄 -->
            <Thumb Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                   Width="20" Height="20" Margin="0,0,2,2" Cursor="SizeNWSE"
                   DragStarted="ResizeGrip_DragStarted"
                   DragDelta="ResizeGrip_DragDelta"
                   Background="Transparent">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Grid>
                            <Path Data="M4,16 L16,4 M10,16 L16,10 M16,16 L16,16" 
                                  Stroke="{DynamicResource TextTertiaryBrush}" 
                                  StrokeThickness="1.5" 
                                  StrokeStartLineCap="Round" 
                                  StrokeEndLineCap="Round"
                                  HorizontalAlignment="Right" 
                                  VerticalAlignment="Bottom"
                                  Margin="0,0,2,2"/>
                        </Grid>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
        </Grid>
    </Border>
</Window>
