        <!-- 苹果风格侧边栏按钮样式 -->
        <Style x:Key="AppleSidebarBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SidebarInactiveFgBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <!-- 苹果风格 12px 圆角胶囊容器 -->
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" x:Name="b" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="btnScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect x:Name="sidebarShadow" Color="#0084FF" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- 悬停时如果是未选中状态，显示轻微悬浮灰 -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="Background" Value="Transparent"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBgBrush}"/>
                            </MultiTrigger>
                            
                            <!-- 悬停缩放动画 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="1.04" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="1.04" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <!-- 点击按压收缩动画 -->
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="0.94" Duration="0:0:0.08">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="0.94" Duration="0:0:0.08">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.12">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.12">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <!-- 选中态（FontWeight为SemiBold时）冰蓝色呼吸外发光阴影 -->
                            <Trigger Property="FontWeight" Value="SemiBold">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="sidebarShadow" Storyboard.TargetProperty="Opacity" To="0.3" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="sidebarShadow" Storyboard.TargetProperty="BlurRadius" To="12" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="sidebarShadow" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="sidebarShadow" Storyboard.TargetProperty="BlurRadius" To="0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" Background="{DynamicResource WindowBgBrush}" CornerRadius="16" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

            <!-- 窗口底部星光溢光背景层 (极轻度发光叠加) -->
            <Border Grid.RowSpan="3" IsHitTestVisible="False" Opacity="0.08" CornerRadius="16" ClipToBounds="True">
                <Border.Background>
                    <RadialGradientBrush Center="0.85,0.15" GradientOrigin="0.85,0.15" RadiusX="0.7" RadiusY="0.7">
                        <GradientStop Color="#007AFF" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>
            <Border Grid.RowSpan="3" IsHitTestVisible="False" Opacity="0.06" CornerRadius="16" ClipToBounds="True">
                <Border.Background>
                    <RadialGradientBrush Center="0.15,0.85" GradientOrigin="0.15,0.85" RadiusX="0.8" RadiusY="0.8">
                        <GradientStop Color="#5856D6" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
            </Border>

            <!-- 标题栏 (Windows 现代简约风) -->
            <Border Grid.Row="0" Background="{DynamicResource SidebarBgBrush}" Padding="0">
                <Grid Height="44">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- 左侧：应用图标与标题 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                        <Image Source="Resources/icon.png" Width="18" Height="18" Margin="0,0,8,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="Steam" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text=" Switch" FontSize="12" FontWeight="Light" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 中间留空 (可用作拖动区域) -->
                    <Grid Grid.Column="1"/>

                    <!-- 右侧：刷新及控制按钮 (Windows 11 现代简约) -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Stretch">
                        <Button Content="↻" Style="{StaticResource BtnWindow}" Command="{Binding RefreshCommand}" ToolTip="刷新" Width="40" Height="44"/>
                        <Button Content="─" Style="{StaticResource BtnWindow}" Click="Minimize_Click" ToolTip="最小化" Width="46" Height="44"/>
                        <Button Content="✕" Style="{StaticResource BtnClose}" Click="Close_Click" ToolTip="关闭" Width="46" Height="44"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Row="0" Height="0.5" VerticalAlignment="Bottom" Background="{DynamicResource BorderBrush}"/>

            <!-- 主体 (左右分栏，侧边栏通底) -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：全局侧边栏 -->
                <Border Grid.Column="0" Background="{DynamicResource SidebarBgBrush}">
                    <DockPanel Margin="10,10,10,14" LastChildFill="False">
                        <StackPanel DockPanel.Dock="Top">
                            <!-- 账号 -->
                            <Grid Margin="0,0,0,8">
                                <Border x:Name="SideAccentAccount" Width="0" Background="Transparent"/>
                                <Button x:Name="SideAccounts" Style="{StaticResource AppleSidebarBtnStyle}" Click="SideAccounts_Click" ToolTip="账号列表">
                                    <StackPanel>
                                        <TextBlock Text="⚡" FontSize="18" HorizontalAlignment="Center"/>
                                        <TextBlock Text="账号" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            
                            <!-- 游戏 -->
                            <Grid Margin="0,0,0,8">
                                <Border x:Name="SideAccentGame" Width="0" Background="Transparent"/>
                                <Button x:Name="SideGames" Style="{StaticResource AppleSidebarBtnStyle}" Click="SideGames_Click" ToolTip="游戏绑定">
                                    <StackPanel>
                                        <TextBlock Text="🎮" FontSize="18" HorizontalAlignment="Center"/>
                                        <TextBlock Text="游戏" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            
                            <!-- 快速启动 -->
                            <Grid Margin="0,0,0,8">
                                <Border x:Name="SideAccentQuickLaunch" Width="0" Background="Transparent"/>
                                <Button x:Name="SideQuickLaunch" Style="{StaticResource AppleSidebarBtnStyle}" Click="SideQuickLaunch_Click" ToolTip="快速启动">
                                    <StackPanel>
                                        <TextBlock Text="🚀" FontSize="18" HorizontalAlignment="Center"/>
                                        <TextBlock Text="快启" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <!-- 设置放在底部 -->
                        <Grid DockPanel.Dock="Bottom">
                            <Border x:Name="SideAccentSettings" Width="0" Background="Transparent"/>
                            <Button x:Name="SideSettings" Style="{StaticResource AppleSidebarBtnStyle}" Click="SideSettings_Click" ToolTip="设置">
                                <StackPanel>
                                    <TextBlock Text="⚙" FontSize="18" HorizontalAlignment="Center"/>
                                    <TextBlock Text="设置" FontSize="10" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </DockPanel>
                </Border>
                
                <!-- 侧边栏与内容分割线 -->
                <Border Grid.Column="0" Width="0.5" Background="{DynamicResource BorderBrush}" HorizontalAlignment="Right"/>

                <!-- 右侧：主内容区 -->
                <Grid Grid.Column="1" Margin="16,14,16,14">
                    <!-- 账号视图 -->
                    <Grid x:Name="AccountView" Style="{StaticResource FadeInUpViewStyle}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 统计卡片 -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="1.4*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource ShineCardBorder}" Padding="14,11" Margin="0,0,6,0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="当前账号" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                        <TextBlock Text="{Binding CurrentAccountName}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Style="{StaticResource StatusBadgeStyle}" CornerRadius="8" Padding="9,5" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SteamStateText}" Foreground="{DynamicResource SuccessFgBrush}" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource ShineCardBorder}" Padding="14,11" Margin="6,0,6,0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="账号" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                        <TextBlock Text="{Binding AccountCountText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="21" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="绑定" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                        <TextBlock Text="{Binding BindingCountText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="21" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource ShineCardBorder}" Padding="14,11" Margin="6,0,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="游戏" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                        <TextBlock Text="{Binding GameCountText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="21" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="固定" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                        <TextBlock Text="{Binding PinnedCountText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="21" FontWeight="Bold" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.ColumnSpan="2" Text="{Binding InjectorStateText}" Foreground="{DynamicResource AccentBrush}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- 库界面注入 -->
                        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="12,10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="库界面游戏启动" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="在 Steam 库当前游戏旁选择账号，之后点 [启动] 自动切换并运行。" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,3,0,0" TextWrapping="Wrap"/>
                                    <TextBlock Text="⚠️ 开启调试端口，存在账号封禁风险" Foreground="#FF9500" FontSize="11" Margin="0,3,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="注入" Command="{Binding StartInjectorCommand}"
                                        IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}"
                                        Style="{StaticResource SecondaryBtn}" Width="64" Height="32" Margin="10,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- 账号列表 -->
                        <Border Grid.Row="2" Background="{DynamicResource CardBgBrush}" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <ListBox ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount}"
                                     Style="{StaticResource AccountList}" ItemTemplate="{StaticResource AccountItem}" Padding="8,6"/>
                        </Border>
                    </Grid>
 
                        <!-- 游戏视图 -->
                        <Grid x:Name="GameView" Visibility="Collapsed" Style="{StaticResource FadeInUpViewStyle}">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="300"/></Grid.ColumnDefinitions>

                            <!-- 左侧：游戏列表 -->
                            <Grid Grid.Column="0" Margin="0,0,10,0">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <Border Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="10,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,10,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="🔍" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="2,0,8,0" FontSize="13"/>
                                            <TextBox Grid.Column="1" x:Name="GameSearchBox" Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0" CaretBrush="{DynamicResource TextPrimaryBrush}" FontSize="13" Padding="2,0" VerticalAlignment="Center"
                                                      TextChanged="GameSearchBox_TextChanged" GotFocus="GameSearchBox_GotFocus" LostFocus="GameSearchBox_LostFocus"/>
                                            <Button Grid.Column="2" x:Name="GameClearSearch" Content="✕" Width="24" Height="24" FontSize="10" Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}" BorderThickness="0" Cursor="Hand" Click="GameClearSearch_Click" Visibility="Collapsed">
                                                <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="cb" Background="Transparent" CornerRadius="6"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="cb" Property="Background" Value="{DynamicResource HoverBgBrush}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                            </Button>
                                        </Grid>
                                    </Border>
                                    <Button Grid.Column="1" Content="扫描" Click="GameScan_Click" Width="72" Height="38" Style="{StaticResource PrimaryBtn}"/>
                                </Grid>

                                <Grid Grid.Row="1" Margin="2,0,2,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock x:Name="GameScanStatus" Text="已安装游戏" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="选择游戏后绑定启动账号" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" VerticalAlignment="Center"/>
                                </Grid>

                                <Border Grid.Row="2" Background="{DynamicResource CardBgAltBrush}" CornerRadius="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <ListBox x:Name="GameListBox" ItemsSource="{Binding GameList}" SelectedItem="{Binding SelectedGame}"
                                                 Background="Transparent" BorderThickness="0" Padding="8" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ItemContainerStyle="{StaticResource GameListItemStyle}"
                                                 ItemTemplate="{StaticResource GameItemTemplate}"
                                                 VirtualizingStackPanel.IsVirtualizing="True"
                                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                                 ScrollViewer.CanContentScroll="True"/>
                                        <TextBlock x:Name="GameEmptyHint" Text="点击 [扫描] 加载本地 Steam 游戏" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding ShowEmptyHint, Converter={StaticResource BoolToVis}}"/>
                                    </Grid>
                                </Border>


                                <Button Grid.Row="3" Content="+ 手动添加游戏" Click="ManualAddToggle_Click" Margin="0,8,0,0" Height="34" Style="{StaticResource SecondaryBtn}"/>

                                <!-- 手动添加面板 -->
                                <Border Grid.Row="4" x:Name="ManualAddPanel" Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="12,10"
                                        Margin="0,8,0,0" Visibility="Collapsed" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="96"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="AppID" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBox Grid.Column="1" x:Name="ManualAppId" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="7,5" FontSize="12" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="2" Text="游戏名" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBox Grid.Column="3" x:Name="ManualGameName" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="7,5" FontSize="12" Margin="0,0,10,0"/>
                                        <Button Grid.Column="4" Content="添加" Click="ManualAddBinding_Click" Width="58" Height="30" Style="{StaticResource PrimaryBtn}"/>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- 右侧：绑定面板 -->
                            <Border Grid.Column="1" Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Margin="0,0,0,14">
                                        <TextBlock Text="绑定设置" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="为游戏指定启动前切换的 Steam 账号" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <Border Grid.Row="1" Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,12"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="已选游戏" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding SelectedGameName}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,6,0,0"/>
                                            <TextBlock Text="{Binding SelectedGameAppId, StringFormat='AppID: {0}'}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,4,0,0"/>
                                            <Border Style="{StaticResource StatusBadgeStyle}" CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" Margin="0,8,0,0"
                                                    Visibility="{Binding SelectedGameHasBinding, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{Binding SelectedGameBindingAccount, StringFormat='✓ 已绑定: {0}'}" Foreground="#30D158" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Grid.Row="2" Text="选择绑定账号" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <ListBox Grid.Row="3" x:Name="GameAccountList" ItemsSource="{Binding Accounts}"
                                             SelectedItem="{Binding SelectedBindingAccount}" Background="Transparent"
                                             BorderThickness="0" Margin="0,0,0,12" Padding="4">
                                        <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem">
                                            <Setter Property="Height" Value="50"/><Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem">
                                                <Border CornerRadius="8" Margin="0,2" x:Name="abi"
                                                        RenderTransformOrigin="0.5,0.5">
                                                    <Border.RenderTransform>
                                                        <TranslateTransform X="0" Y="0" x:Name="trans"/>
                                                    </Border.RenderTransform>
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#000000" BlurRadius="4" ShadowDepth="1" Opacity="0" x:Name="shadow"/>
                                                    </Border.Effect>
                                                    <Grid>
                                                        <Border CornerRadius="8" Background="{DynamicResource HoverBgBrush}" Opacity="0" x:Name="hoverBg"/>
                                                        <Border CornerRadius="8" Background="{DynamicResource SelectedBgBrush}" Opacity="0" x:Name="selectBg">
                                                            <Border.Effect>
                                                                <DropShadowEffect Color="#0084FF" BlurRadius="10" ShadowDepth="0" Opacity="0.25"/>
                                                            </Border.Effect>
                                                        </Border>
                                                        <Grid Margin="9,0">
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Width="34" Height="34" CornerRadius="17" Background="{DynamicResource AvatarBgBrush}" VerticalAlignment="Center">
                                                                <Image Source="{Binding Avatar}" Stretch="UniformToFill"><Image.Clip><EllipseGeometry Center="17,17" RadiusX="17" RadiusY="17"/></Image.Clip></Image>
                                                            </Border>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                                                 <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                                                                 <TextBlock Text="{Binding Username}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="10"/>
                                                            </StackPanel>
                                                            <Border Grid.Column="2" Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVis}}" 
                                                                    Style="{StaticResource StatusBadgeStyle}" CornerRadius="5" Padding="6,2" VerticalAlignment="Center">
                                                                <TextBlock Text="当前" Foreground="#30D158" FontSize="10" FontWeight="SemiBold"/>
                                                            </Border>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="hoverBg" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                                                    <DoubleAnimation Storyboard.TargetName="trans" Storyboard.TargetProperty="Y" To="-2" Duration="0:0:0.15">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <CubicEase EasingMode="EaseOut"/>
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                    <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="Opacity" To="0.15" Duration="0:0:0.15"/>
                                                                    <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="BlurRadius" To="10" Duration="0:0:0.15"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.EnterActions>
                                                        <Trigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="hoverBg" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                                                    <DoubleAnimation Storyboard.TargetName="trans" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.15">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <CubicEase EasingMode="EaseOut"/>
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                    <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                                                    <DoubleAnimation Storyboard.TargetName="shadow" Storyboard.TargetProperty="BlurRadius" To="4" Duration="0:0:0.15"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.ExitActions>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="selectBg" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.EnterActions>
                                                        <Trigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
