<Window x:Class="SteamSwitcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam Switch"
        Icon="Resources/steam.ico"
        Height="760" Width="1080"
        MinHeight="620" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolConverter x:Key="InverseBool" xmlns:local="clr-namespace:SteamSwitcher.Converters"/>
        <local:ThemeToBoolConverter x:Key="ThemeToBool" xmlns:local="clr-namespace:SteamSwitcher.Converters"/>

        <!-- 全局滚动条样式 -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ScrollBar">
                <Grid>
                    <Border Background="Transparent" CornerRadius="3" x:Name="track"/>
                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                        <Track.Thumb>
                            <Thumb Cursor="Hand" x:Name="thumb">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="{DynamicResource ScrollThumbBrush}" CornerRadius="3" x:Name="tb"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="tb" Property="Background" Value="{DynamicResource ScrollThumbHoverBrush}"/></Trigger>
                                            <Trigger Property="IsDragging" Value="True"><Setter TargetName="tb" Property="Background" Value="{DynamicResource ScrollThumbDragBrush}"/></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Track.Thumb>
                        <Track.DecreaseRepeatButton>
                            <RepeatButton Command="ScrollBar.PageUpCommand" Style="{x:Null}">
                                <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template>
                            </RepeatButton>
                        </Track.DecreaseRepeatButton>
                        <Track.IncreaseRepeatButton>
                            <RepeatButton Command="ScrollBar.PageDownCommand" Style="{x:Null}">
                                <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template>
                            </RepeatButton>
                        </Track.IncreaseRepeatButton>
                    </Track>
                </Grid>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ScrollViewer">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <ScrollContentPresenter Grid.Column="0" x:Name="PART_ScrollContentPresenter" ContentTemplate="{TemplateBinding ContentTemplate}" CanContentScroll="{TemplateBinding CanContentScroll}"/>
                    <ScrollBar Grid.Column="1" x:Name="PART_VerticalScrollBar" Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" Value="{TemplateBinding VerticalOffset}" Maximum="{TemplateBinding ScrollableHeight}" ViewportSize="{TemplateBinding ViewportHeight}" Width="6" Margin="2,3,2,3"/>
                </Grid>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style x:Key="BtnClose" TargetType="Button">
            <Setter Property="Width" Value="36"/><Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="FontSize" Value="12"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}" x:Name="bg"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="#E81123"/><Setter Property="Foreground" Value="White"/></Trigger></ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style x:Key="BtnWindow" TargetType="Button">
            <Setter Property="Width" Value="36"/><Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="FontSize" Value="12"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}" x:Name="bg"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="{DynamicResource HoverBgBrush}"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/></Trigger></ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style x:Key="BtnSettings" TargetType="Button">
            <Setter Property="Width" Value="36"/><Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="FontSize" Value="14"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}" CornerRadius="6" x:Name="bg"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bg" Property="Background" Value="{DynamicResource HoverBgBrush}"/><Setter Property="Foreground" Value="White"/></Trigger></ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Height" Value="38"/><Setter Property="Background" Value="#0A84FF"/><Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Medium"/><Setter Property="FontSize" Value="13"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}" CornerRadius="10" x:Name="b"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#409CFF"/></Trigger>
                    <Trigger Property="IsPressed" Value="True"><Setter TargetName="b" Property="Background" Value="#0066CC"/></Trigger>
                    <Trigger Property="IsEnabled" Value="False"><Setter TargetName="b" Property="Background" Value="{DynamicResource SelectedBgBrush2}"/><Setter Property="Foreground" Value="#55FFFFFF"/></Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource BtnSecondaryFgBrush}"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}" CornerRadius="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" x:Name="b"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="{DynamicResource BtnHoverBgBrush}"/></Trigger>
                    <Trigger Property="IsEnabled" Value="False"><Setter TargetName="b" Property="Background" Value="{DynamicResource BtnDisabledBgBrush}"/><Setter Property="Foreground" Value="{DynamicResource BtnDisabledFgBrush}"/></Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style x:Key="BtnRefresh" TargetType="Button">
            <Setter Property="Width" Value="36"/><Setter Property="Height" Value="36"/><Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/><Setter Property="BorderThickness" Value="0"/><Setter Property="FontSize" Value="16"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}" CornerRadius="8" x:Name="b"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBgBrush}"/><Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/></Trigger></ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style x:Key="AppCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/><Setter Property="FontSize" Value="12"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="CheckBox">
                <StackPanel Orientation="Horizontal">
                    <Border Width="18" Height="18" CornerRadius="5" Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1.5" x:Name="cb">
                        <TextBlock Text="✓" Foreground="White" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" x:Name="ck"/>
                    </Border>
                    <ContentPresenter VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsChecked" Value="True"><Setter TargetName="cb" Property="Background" Value="#0A84FF"/><Setter TargetName="cb" Property="BorderBrush" Value="#0A84FF"/><Setter TargetName="ck" Property="Visibility" Value="Visible"/></Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style x:Key="SwitchToggle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="CheckBox">
                <Border Width="44" Height="25" CornerRadius="12.5" Background="{DynamicResource ToggleTrackBgBrush}"
                        BorderBrush="{DynamicResource ToggleTrackBorderBrush}" BorderThickness="1" x:Name="track">
                    <Ellipse Width="18" Height="18" Fill="{DynamicResource ToggleThumbBrush}" HorizontalAlignment="Left" Margin="3,0,0,0" x:Name="thumb"/>
                    <Border.Effect>
                        <DropShadowEffect Color="#5B9BFF" BlurRadius="8" ShadowDepth="0" Opacity="0.10"/>
                    </Border.Effect>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="track" Property="Background" Value="{DynamicResource ToggleTrackCheckedBgBrush}"/>
                        <Setter TargetName="track" Property="BorderBrush" Value="{DynamicResource ToggleTrackCheckedBorderBrush}"/>
                        <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                        <Setter TargetName="thumb" Property="Margin" Value="0,0,3,0"/>
                        <Setter TargetName="thumb" Property="Fill" Value="White"/>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="track" Property="Opacity" Value="0.9"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="track" Property="Opacity" Value="0.45"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style x:Key="SettingsRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/><Setter Property="FontSize" Value="11"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="RadioButton">
                <StackPanel Orientation="Horizontal">
                    <Border Width="16" Height="16" CornerRadius="8" Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" x:Name="rb">
                        <Ellipse Width="7" Height="7" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" x:Name="dot"/>
                    </Border>
                    <ContentPresenter VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsChecked" Value="True"><Setter TargetName="rb" Property="Background" Value="#0A84FF"/><Setter TargetName="rb" Property="BorderBrush" Value="#0A84FF"/><Setter TargetName="dot" Property="Visibility" Value="Visible"/></Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style x:Key="AccountList" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,0"/><Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemContainerStyle"><Setter.Value><Style TargetType="ListBoxItem">
                <Setter Property="Height" Value="76"/><Setter Property="Margin" Value="0,2"/><Setter Property="Padding" Value="0"/><Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem">
                    <Border Background="{TemplateBinding Background}" CornerRadius="14" x:Name="b"><ContentPresenter/></Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBgBrush}"/></Trigger>
                        <Trigger Property="IsSelected" Value="True"><Setter TargetName="b" Property="Background" Value="{DynamicResource SelectedBgBrush}"/></Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate></Setter.Value></Setter>
            </Style></Setter.Value></Setter>
        </Style>

        <DataTemplate x:Key="AccountItem">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="46" Height="46" CornerRadius="12" Background="{DynamicResource CardBgBrush}" VerticalAlignment="Center">
                    <Border.Clip><RectangleGeometry Rect="0,0,46,46" RadiusX="12" RadiusY="12"/></Border.Clip>
                    <Image Source="{Binding Avatar}" Stretch="UniformToFill"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="Medium"/>
                    <TextBlock Text="{Binding Username}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
                <Border Grid.Column="2" VerticalAlignment="Center" Margin="8,0" Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVis}}" Background="#2230D158" CornerRadius="8" Padding="10,5">
                    <TextBlock Text="当前" Foreground="#30D158" FontSize="11" FontWeight="SemiBold"/>
                </Border>
                <ToggleButton Grid.Column="3" VerticalAlignment="Center" IsChecked="{Binding IsPinned}" Width="36" Height="36" Cursor="Hand" Background="Transparent">
                    <ToggleButton.Style><Style TargetType="ToggleButton"><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Width="36" Height="36" x:Name="b">
                            <TextBlock Text="📌" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.4" x:Name="i"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBgBrush}"/><Setter TargetName="i" Property="Opacity" Value="0.8"/></Trigger>
                            <Trigger Property="IsChecked" Value="True"><Setter TargetName="i" Property="Opacity" Value="1"/><Setter TargetName="i" Property="Text" Value="📍"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate></Setter.Value></Setter></Style></ToggleButton.Style>
                </ToggleButton>
            </Grid>
        </DataTemplate>

                        <DataTemplate x:Key="GameItemTemplate">
                            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="12,10" Margin="0,3"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="42" Height="42" CornerRadius="10" Background="{DynamicResource AccentBgBrush}" Margin="0,0,12,0">
                                        <Border.Clip>
                                            <RectangleGeometry Rect="0,0,42,42" RadiusX="10" RadiusY="10"/>
                                        </Border.Clip>
                                        <Grid>
                                            <TextBlock Text="🎮" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Image Source="{Binding IconPath}" Stretch="UniformToFill"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <Border Background="{DynamicResource CardBgAltBrush}" CornerRadius="5" Padding="7,2">
                                                <TextBlock Text="{Binding AppId, StringFormat='AppID {0}'}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10"/>
                                            </Border>
                                            <Border Background="{DynamicResource SuccessBgBrush}" CornerRadius="5" Padding="7,2" Margin="6,0,0,0"
                                                    Visibility="{Binding HasBinding, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="已绑定" Foreground="#30D158" FontSize="10" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding SizeDisplay}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="10"
                                               VerticalAlignment="Center" Margin="14,0,0,0"/>
                                    <ToggleButton Grid.Column="3" VerticalAlignment="Center" Width="34" Height="34" Cursor="Hand" Margin="8,0,0,0"
                                                  IsChecked="{Binding IsPinned, Mode=OneWay}" Click="GameItemPinToggle_Click">
                                        <ToggleButton.Template><ControlTemplate TargetType="ToggleButton">
                                            <Border Background="{DynamicResource CardBgAltBrush}" CornerRadius="8" Width="34" Height="34" x:Name="gpb">
                                                <TextBlock Text="📌" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.35" x:Name="gpi"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="gpb" Property="Background" Value="{DynamicResource ToggleHoverBgBrush}"/><Setter TargetName="gpi" Property="Opacity" Value="0.75"/></Trigger>
                                                <Trigger Property="IsChecked" Value="True"><Setter TargetName="gpb" Property="Background" Value="{DynamicResource ToggleCheckedBgBrush}"/><Setter TargetName="gpi" Property="Opacity" Value="1"/><Setter TargetName="gpi" Property="Text" Value="📍"/></Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate></ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                        </DataTemplate>

        <Style x:Key="GameListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem">
                <Border Background="{TemplateBinding Background}" CornerRadius="10" x:Name="b">
                    <ContentPresenter/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBgBrush}"/></Trigger>
                    <Trigger Property="IsSelected" Value="True"><Setter TargetName="b" Property="Background" Value="{DynamicResource SelectedBgBrush2}"/></Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <!-- 圆角调整大小手柄 -->
        <Style TargetType="ResizeGrip">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ResizeGrip">
                        <Grid Background="Transparent" Width="16" Height="16">
                            <Path Data="M8,14 L14,8 M11,14 L14,11 M14,14 L14,14" 
                                  Stroke="{DynamicResource TextTertiaryBrush}" 
                                  StrokeThickness="1.5" 
                                  StrokeStartLineCap="Round" 
                                  StrokeEndLineCap="Round"
                                  HorizontalAlignment="Right" 
                                  VerticalAlignment="Bottom"
                                  Margin="0,0,2,2"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" Background="{DynamicResource WindowBgBrush}" CornerRadius="12" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="{DynamicResource WindowBgBrush}" Padding="0">
                <Grid Height="40">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                        <Image Source="Resources/icon.png" Width="24" Height="24" Margin="0,0,10,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="Steam" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text=" Switch" FontSize="15" FontWeight="Light" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="↻" Style="{StaticResource BtnRefresh}" Command="{Binding RefreshCommand}" ToolTip="刷新"/>
                        <Button Content="─" Style="{StaticResource BtnWindow}" Click="Minimize_Click"/>
                        <Button Content="□" Style="{StaticResource BtnWindow}" Click="Maximize_Click"/>
                        <Button Content="✕" Style="{StaticResource BtnClose}" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
            <Border Grid.Row="0" Height="0.5" VerticalAlignment="Bottom" Background="{DynamicResource BorderBrush}"/>

            <!-- 主体 -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>

                <!-- 统计卡片 -->
                <Grid Grid.Row="0" Margin="16,10,16,8">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="1.4*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="14,11" Margin="0,0,6,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="当前账号" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding CurrentAccountName}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="{DynamicResource SuccessBgBrush}" CornerRadius="8" Padding="9,5" VerticalAlignment="Center">
                                <TextBlock Text="{Binding SteamStateText}" Foreground="{DynamicResource SuccessFgBrush}" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="14,11" Margin="6,0,6,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="账号" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding AccountCountText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="21" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="绑定" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding BindingCountText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="21" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="14,11" Margin="6,0,0,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="游戏" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding GameCountText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="21" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="固定" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                                <TextBlock Text="{Binding PinnedCountText}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="21" FontWeight="Bold" Margin="0,4,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.ColumnSpan="2" Text="{Binding InjectorStateText}" Foreground="{DynamicResource AccentBrush}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 库界面注入 -->
                <Border Grid.Row="1" Background="{DynamicResource CardBgBrush}" CornerRadius="8" Padding="10,8" Margin="16,0,16,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="库界面游戏启动" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="在 Steam 库当前游戏旁选择账号，之后点 [启动] 自动切换并运行。" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,3,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="⚠️ 开启调试端口，存在账号封禁风险" Foreground="#FF9500" FontSize="11" Margin="0,3,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="注入" Command="{Binding StartInjectorCommand}"
                                IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}"
                                Style="{StaticResource SecondaryBtn}" Width="64" Height="32" Margin="10,0,0,0"/>
                    </Grid>
                </Border>

                <!-- 侧边栏 + 内容 -->
                <Grid Grid.Row="2" Margin="0,0,0,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Width="68" Background="{DynamicResource SidebarBgBrush}">
                        <DockPanel Margin="10,14,10,14" LastChildFill="False">
                            <StackPanel DockPanel.Dock="Top">
                                <Grid Margin="0,0,0,6">
                                    <Border x:Name="SideAccentAccount" Width="3" CornerRadius="2" Background="#0A84FF" HorizontalAlignment="Left" Margin="-10,0,0,0"/>
                                    <Button x:Name="SideAccounts" Width="48" Height="48" Cursor="Hand" Click="SideAccounts_Click">
                                        <Button.Style><Style TargetType="Button">
                                            <Setter Property="Background" Value="{DynamicResource SelectedBgBrush}"/><Setter Property="Foreground" Value="#0A84FF"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/><Setter Property="BorderThickness" Value="0"/><Setter Property="ToolTip" Value="账号列表"/>
                                            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="12" x:Name="b">
                                                    <StackPanel>
                                                        <TextBlock Text="⚡" FontSize="17" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="账号" FontSize="10" Foreground="{TemplateBinding Foreground}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#24FFFFFF"/></Trigger></ControlTemplate.Triggers>
                                            </ControlTemplate></Setter.Value></Setter>
                                        </Style></Button.Style>
                                    </Button>
                                </Grid>
                                <Grid Margin="0,0,0,6">
                                    <Border x:Name="SideAccentGame" Width="3" CornerRadius="2" Background="Transparent" HorizontalAlignment="Left" Margin="-10,0,0,0"/>
                                    <Button x:Name="SideGames" Width="48" Height="48" Cursor="Hand" Click="SideGames_Click">
                                        <Button.Style><Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="#8E8E96"/>
                                            <Setter Property="FontWeight" Value="Normal"/><Setter Property="BorderThickness" Value="0"/><Setter Property="ToolTip" Value="游戏绑定"/>
                                            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="12" x:Name="b">
                                                    <StackPanel>
                                                        <TextBlock Text="🎮" FontSize="17" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="游戏" FontSize="10" Foreground="{TemplateBinding Foreground}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBgBrush}"/></Trigger></ControlTemplate.Triggers>
                                            </ControlTemplate></Setter.Value></Setter>
                                        </Style></Button.Style>
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <Grid DockPanel.Dock="Bottom">
                                <Border x:Name="SideAccentSettings" Width="3" CornerRadius="2" Background="Transparent" HorizontalAlignment="Left" Margin="-10,0,0,0"/>
                                <Button x:Name="SideSettings" Width="48" Height="48" Cursor="Hand" Click="SideSettings_Click">
                                    <Button.Style><Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="#8E8E96"/>
                                        <Setter Property="FontWeight" Value="Normal"/><Setter Property="BorderThickness" Value="0"/><Setter Property="ToolTip" Value="设置"/>
                                        <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="12" x:Name="b">
                                                <StackPanel>
                                                    <TextBlock Text="⚙" FontSize="17" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="设置" FontSize="10" Foreground="{TemplateBinding Foreground}" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBgBrush}"/></Trigger></ControlTemplate.Triggers>
                                        </ControlTemplate></Setter.Value></Setter>
                                    </Style></Button.Style>
                                </Button>
                            </Grid>
                        </DockPanel>
                    </Border>
                    <Border Grid.Column="0" Width="1" Background="{DynamicResource BorderBrush}" HorizontalAlignment="Right"/>

                    <!-- 主内容 -->
                    <Grid Grid.Column="1" Margin="0,0,12,0">
                        <!-- 账号视图 -->
                        <Grid x:Name="AccountView">
                            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <ListBox ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount}"
                                         Style="{StaticResource AccountList}" ItemTemplate="{StaticResource AccountItem}" Padding="8,6"/>
                            </Border>
                        </Grid>

                        <!-- 游戏视图 -->
                        <Grid x:Name="GameView" Visibility="Collapsed">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="300"/></Grid.ColumnDefinitions>

                            <!-- 左侧：游戏列表 -->
                            <Grid Grid.Column="0" Margin="0,0,10,0">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <Border Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="10,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,10,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="🔍" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="2,0,8,0" FontSize="13"/>
                                            <TextBox Grid.Column="1" x:Name="GameSearchBox" Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0" CaretBrush="{DynamicResource TextPrimaryBrush}" FontSize="13" Padding="2,0" VerticalAlignment="Center"
                                                      TextChanged="GameSearchBox_TextChanged" GotFocus="GameSearchBox_GotFocus" LostFocus="GameSearchBox_LostFocus"/>
                                            <Button Grid.Column="2" x:Name="GameClearSearch" Content="✕" Width="24" Height="24" FontSize="10" Background="Transparent" Foreground="{DynamicResource TextSecondaryBrush}" BorderThickness="0" Cursor="Hand" Click="GameClearSearch_Click" Visibility="Collapsed">
                                                <Button.Template><ControlTemplate TargetType="Button"><Border x:Name="cb" Background="Transparent" CornerRadius="6"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                                <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="cb" Property="Background" Value="{DynamicResource HoverBgBrush}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                            </Button>
                                        </Grid>
                                    </Border>
                                    <Button Grid.Column="1" Content="扫描" Click="GameScan_Click" Width="72" Height="38" FontSize="12"
                                            Background="{DynamicResource AccentBrush}" Foreground="White" FontWeight="Medium" Cursor="Hand" BorderThickness="0">
                                        <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="10" x:Name="s"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="s" Property="Background" Value="#409CFF"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                    </Button>
                                </Grid>

                                <Grid Grid.Row="1" Margin="2,0,2,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock x:Name="GameScanStatus" Text="已安装游戏" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="选择游戏后绑定启动账号" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" VerticalAlignment="Center"/>
                                </Grid>

                                <Border Grid.Row="2" Background="{DynamicResource CardBgAltBrush}" CornerRadius="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <ListBox x:Name="GameListBox" ItemsSource="{Binding GameList}" SelectedItem="{Binding SelectedGame}"
                                                 Background="Transparent" BorderThickness="0" Padding="8" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ItemContainerStyle="{StaticResource GameListItemStyle}"
                                                 ItemTemplate="{StaticResource GameItemTemplate}"
                                                 VirtualizingStackPanel.IsVirtualizing="True"
                                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                                 ScrollViewer.CanContentScroll="True"/>
                                        <TextBlock x:Name="GameEmptyHint" Text="点击 [扫描] 加载本地 Steam 游戏" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding ShowEmptyHint, Converter={StaticResource BoolToVis}}"/>
                                    </Grid>
                                </Border>

                                <Button Grid.Row="3" Content="+ 手动添加游戏" Click="ManualAddToggle_Click" Margin="0,8,0,0" Height="34" FontSize="12"
                                        Background="{DynamicResource CardBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Medium" Cursor="Hand" BorderThickness="0">
                                    <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="9" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" x:Name="ma"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                    <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="ma" Property="Background" Value="{DynamicResource BtnHoverBgBrush}"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                </Button>

                                <!-- 手动添加面板 -->
                                <Border Grid.Row="4" x:Name="ManualAddPanel" Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="12,10"
                                        Margin="0,8,0,0" Visibility="Collapsed" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="96"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="AppID" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBox Grid.Column="1" x:Name="ManualAppId" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="7,5" FontSize="12" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="2" Text="游戏名" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBox Grid.Column="3" x:Name="ManualGameName" Background="{DynamicResource InputBgBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="7,5" FontSize="12" Margin="0,0,10,0"/>
                                        <Button Grid.Column="4" Content="添加" Click="ManualAddBinding_Click" Width="58" Height="30" FontSize="12"
                                                Background="{DynamicResource AccentBrush}" Foreground="White" FontWeight="Medium" Cursor="Hand" BorderThickness="0">
                                            <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="8" x:Name="mab"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                            <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="mab" Property="Background" Value="#409CFF"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                        </Button>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- 右侧：绑定面板 -->
                            <Border Grid.Column="1" Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="16" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Margin="0,0,0,14">
                                        <TextBlock Text="绑定设置" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold"/>
                                        <TextBlock Text="为游戏指定启动前切换的 Steam 账号" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <Border Grid.Row="1" Background="{DynamicResource CardBgBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,12"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="已选游戏" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding SelectedGameName}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,6,0,0"/>
                                            <TextBlock Text="{Binding SelectedGameAppId, StringFormat='AppID: {0}'}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="11" Margin="0,4,0,0"/>
                                            <Border Background="{DynamicResource SuccessBgBrush}" CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" Margin="0,8,0,0"
                                                    Visibility="{Binding SelectedGameHasBinding, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{Binding SelectedGameBindingAccount, StringFormat='✓ 已绑定: {0}'}" Foreground="#30D158" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Grid.Row="2" Text="选择绑定账号" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <ListBox Grid.Row="3" x:Name="GameAccountList" ItemsSource="{Binding Accounts}"
                                             SelectedItem="{Binding SelectedBindingAccount}" Background="{DynamicResource CardBgAltBrush}"
                                             BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,12" Padding="4">
                                        <ListBox.ItemContainerStyle><Style TargetType="ListBoxItem">
                                            <Setter Property="Height" Value="50"/><Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Margin="0,2" x:Name="abi" Padding="9,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="17" Background="{DynamicResource AvatarBgBrush}" VerticalAlignment="Center">
                                                            <Image Source="{Binding Avatar}" Stretch="UniformToFill"><Image.Clip><EllipseGeometry Center="17,17" RadiusX="17" RadiusY="17"/></Image.Clip></Image>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                                             <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                                                             <TextBlock Text="{Binding Username}" Foreground="{DynamicResource TextTertiaryBrush}" FontSize="10"/>
                                                        </StackPanel>
                                                        <Border Grid.Column="2" Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVis}}" Background="{DynamicResource SuccessBgBrush}" CornerRadius="5" Padding="6,2" VerticalAlignment="Center">
                                                            <TextBlock Text="当前" Foreground="#30D158" FontSize="10" FontWeight="SemiBold"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="abi" Property="Background" Value="{DynamicResource HoverBgBrush}"/></Trigger>
                                                    <Trigger Property="IsSelected" Value="True"><Setter TargetName="abi" Property="Background" Value="{DynamicResource SelectedBgBrush}"/></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate></Setter.Value></Setter>
                                        </Style></ListBox.ItemContainerStyle>
                                    </ListBox>

                                    <StackPanel Grid.Row="4">
                                        <Button Content="保存绑定" Click="GameSaveBinding_Click" Height="38" FontSize="13" Margin="0,0,0,8"
                                                Background="#0A84FF" Foreground="White" FontWeight="SemiBold" Cursor="Hand" BorderThickness="0">
                                            <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="10" x:Name="sb"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                            <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="sb" Property="Background" Value="#409CFF"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                        </Button>
                                        <Button Content="删除绑定" Click="GameRemoveBinding_Click" Height="36" FontSize="12" Margin="0,0,0,8"
                                                Background="#FF453A" Foreground="White" FontWeight="SemiBold" Cursor="Hand" BorderThickness="0"
                                                Visibility="{Binding SelectedGameHasBinding, Converter={StaticResource BoolToVis}}">
                                            <Button.Template><ControlTemplate TargetType="Button"><Border Background="{TemplateBinding Background}" CornerRadius="10" x:Name="rb"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                                            <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="rb" Property="Background" Value="#FF6960"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Button.Template>
                                        </Button>
                                        <ToggleButton x:Name="GamePinToggle" IsChecked="{Binding SelectedGame.IsPinned, Mode=OneWay, FallbackValue=False}"
                                                      Click="GamePinToggle_Click" Height="34" Cursor="Hand" HorizontalAlignment="Center">
                                            <ToggleButton.Template><ControlTemplate TargetType="ToggleButton">
                                                <Border Background="{DynamicResource ToggleBgBrush}" CornerRadius="9" Width="128" Height="34" x:Name="pb">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock x:Name="pi" Text="📌" FontSize="14" VerticalAlignment="Center" Opacity="0.35"/>
                                                        <TextBlock x:Name="pt" Text="固定到任务栏" FontSize="12" Foreground="#8E8E96" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="pb" Property="Background" Value="{DynamicResource ToggleHoverBgBrush}"/><Setter TargetName="pi" Property="Opacity" Value="0.7"/></Trigger>
                                                    <Trigger Property="IsChecked" Value="True"><Setter TargetName="pi" Property="Opacity" Value="1"/><Setter TargetName="pi" Property="Text" Value="📍"/><Setter TargetName="pt" Property="Foreground" Value="#0A84FF"/></Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate></ToggleButton.Template>
                                        </ToggleButton>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- 设置视图 -->
                        <Grid x:Name="SettingsView" Visibility="Collapsed">
                            <Border Background="{DynamicResource CardBgAltBrush}" CornerRadius="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8">
                                    <StackPanel>
                                        <Border Background="{DynamicResource AccentBgBrush}" CornerRadius="14" Margin="6,6,6,10" Padding="16,14"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <Border Width="36" Height="36" CornerRadius="12" Background="{DynamicResource AccentBgBrush}" Margin="0,0,12,0">
                                                    <TextBlock Text="⚙" Foreground="{DynamicResource AccentBrush}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="设置" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="17" FontWeight="SemiBold"/>
                                                    <TextBlock Text="管理启动、游戏库注入、任务栏常驻、桌面悬浮窗和外观行为" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <TextBlock Text="外观" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="14,2,14,6"/>
                                        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="14" Margin="6,0,6,10" Padding="0"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                            <StackPanel>
                                                <Border Padding="14,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="暗黑模式" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="切换暗黑与白色现代化界面风格" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                        <CheckBox Grid.Column="1" IsChecked="{Binding IsDarkTheme}" Checked="ThemeToggle_Changed" Unchecked="ThemeToggle_Changed" Style="{StaticResource SwitchToggle}" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Text="常规行为" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="14,2,14,6"/>
                                        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="14" Margin="6,0,6,10" Padding="0"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                            <StackPanel>
                                                <Border Padding="14,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="切换后自动启动 Steam" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="账号切换成功后自动拉起 Steam 客户端" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                        <CheckBox Grid.Column="1" IsChecked="{Binding AutoStartSteam}" Style="{StaticResource SwitchToggle}" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                                <Border Background="{DynamicResource SeparatorBrush}" Height="0.5" Margin="14,0"/>
                                                <Border Padding="14,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="关闭时最小化到托盘" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="点关闭按钮时隐藏窗口，仍可从托盘恢复" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                        <CheckBox Grid.Column="1" IsChecked="{Binding MinimizeToTray}" Style="{StaticResource SwitchToggle}" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                                <Border Background="{DynamicResource SeparatorBrush}" Height="0.5" Margin="14,0"/>
                                                <Border Padding="14,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="开机自动启动" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="写入当前用户启动项，登录 Windows 后自动运行" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                        <CheckBox Grid.Column="1" IsChecked="{Binding StartWithWindows}" Style="{StaticResource SwitchToggle}" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Text="游戏与库界面" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="14,2,14,6"/>
                                        <Border Background="{DynamicResource CardBgBrush}" CornerRadius="14" Margin="6,0,6,10" Padding="0"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                            <StackPanel>
                                                <Border Padding="14,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="启动时自动扫描游戏" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="打开应用后刷新已安装游戏、图标和绑定状态" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                        <CheckBox Grid.Column="1" IsChecked="{Binding AutoScanGamesOnStartup}" Style="{StaticResource SwitchToggle}" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                                <Border Background="{DynamicResource SeparatorBrush}" Height="0.5" Margin="14,0"/>
                                                <Border Padding="14,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="启动固定游戏前确认" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                                            <TextBlock Text="点击任务栏固定游戏时先确认，避免误切账号和启动游戏" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                        <CheckBox Grid.Column="1" IsChecked="{Binding ConfirmBeforeGameLaunch}" Style="{StaticResource SwitchToggle}" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                                <Border Background="{DynamicResource SeparatorBrush}" Height="0.5" Margin="14,0"/>
                                                <Border Padding="14,12">
