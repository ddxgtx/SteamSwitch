<Window x:Class="SteamSwitcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam Switch"
        Icon="Resources/steam.ico"
        Height="760" Width="1080"
        MinHeight="620" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolConverter x:Key="InverseBool" xmlns:local="clr-namespace:SteamSwitcher.Converters"/>
        <local:ThemeToBoolConverter x:Key="ThemeToBool" xmlns:local="clr-namespace:SteamSwitcher.Converters"/>

        <!-- 全局滚动条样式 -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ScrollBar">
                <Grid>
                    <Border Background="Transparent" CornerRadius="3" x:Name="track"/>
                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                        <Track.Thumb>
                            <Thumb Cursor="Hand" x:Name="thumb">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="{DynamicResource ScrollThumbBrush}" CornerRadius="3" x:Name="tb"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="tb" Property="Background" Value="{DynamicResource ScrollThumbHoverBrush}"/></Trigger>
                                            <Trigger Property="IsDragging" Value="True"><Setter TargetName="tb" Property="Background" Value="{DynamicResource ScrollThumbDragBrush}"/></Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Track.Thumb>
                        <Track.DecreaseRepeatButton>
                            <RepeatButton Command="ScrollBar.PageUpCommand" Style="{x:Null}">
                                <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template>
                            </RepeatButton>
                        </Track.DecreaseRepeatButton>
                        <Track.IncreaseRepeatButton>
                            <RepeatButton Command="ScrollBar.PageDownCommand" Style="{x:Null}">
                                <RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></RepeatButton.Template>
                            </RepeatButton>
                        </Track.IncreaseRepeatButton>
                    </Track>
                </Grid>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ScrollViewer">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <ScrollContentPresenter Grid.Column="0" x:Name="PART_ScrollContentPresenter" ContentTemplate="{TemplateBinding ContentTemplate}" CanContentScroll="{TemplateBinding CanContentScroll}"/>
                    <ScrollBar Grid.Column="1" x:Name="PART_VerticalScrollBar" Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" Value="{TemplateBinding VerticalOffset}" Maximum="{TemplateBinding ScrollableHeight}" ViewportSize="{TemplateBinding ViewportHeight}" Width="6" Margin="2,3,2,3"/>
                </Grid>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style x:Key="BtnClose" TargetType="Button">
            <Setter Property="Width" Value="36"/><Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="FontSize" Value="12"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}" x:Name="bg">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="bg" Property="Background" Value="#E81123"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style x:Key="BtnWindow" TargetType="Button">
            <Setter Property="Width" Value="36"/><Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="FontSize" Value="12"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}" CornerRadius="4" x:Name="bg">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource HoverBgBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <Style x:Key="BtnSettings" TargetType="Button">
            <Setter Property="Width" Value="36"/><Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/><Setter Property="FontSize" Value="14"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}" CornerRadius="6" x:Name="bg">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="bg" Property="Background" Value="{DynamicResource HoverBgBrush}"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <!-- 主按钮 (带微缩放动画与平滑过渡) -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}" CornerRadius="10" x:Name="b">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="btnScale" ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                    <Grid>
                        <!-- Hover 亮色遮罩 -->
                        <Border CornerRadius="10" Background="#24FFFFFF" Opacity="0" x:Name="hoverMask"/>
                        <!-- Pressed 暗色遮罩 -->
                        <Border CornerRadius="10" Background="#14000000" Opacity="0" x:Name="pressedMask"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="hoverMask" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="1.03" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="1.03" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="hoverMask" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="pressedMask" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.05"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="0.97" Duration="0:0:0.05"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="0.97" Duration="0:0:0.05"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="pressedMask" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="1.03" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="1.03" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="b" Property="Background" Value="{DynamicResource BtnDisabledBgBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource BtnDisabledFgBrush}"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <!-- 次要按钮 -->
        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}" CornerRadius="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" x:Name="b">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="btnScale" ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Border CornerRadius="10" Background="{DynamicResource HoverBgBrush}" Opacity="0" x:Name="hoverMask"/>
                        <Border CornerRadius="10" Background="#10000000" Opacity="0" x:Name="pressedMask"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="hoverMask" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="1.03" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="1.03" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="hoverMask" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="pressedMask" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.05"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="0.97" Duration="0:0:0.05"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="0.97" Duration="0:0:0.05"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="pressedMask" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="1.03" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="1.03" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="b" Property="Background" Value="{DynamicResource BtnDisabledBgBrush}"/>
                        <Setter TargetName="b" Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource BtnDisabledFgBrush}"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <!-- 危险动作按钮 (带微缩放动画与平滑过渡) -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#FF453A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}" CornerRadius="10" x:Name="b">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="btnScale" ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                    <Grid>
                        <!-- Hover 亮色遮罩 -->
                        <Border CornerRadius="10" Background="#24FFFFFF" Opacity="0" x:Name="hoverMask"/>
                        <!-- Pressed 暗色遮罩 -->
                        <Border CornerRadius="10" Background="#14000000" Opacity="0" x:Name="pressedMask"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="hoverMask" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="1.03" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="1.03" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="hoverMask" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="pressedMask" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.05"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="0.95" Duration="0:0:0.05"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="0.95" Duration="0:0:0.05"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="pressedMask" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="1.0" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="1.0" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="b" Property="Background" Value="{DynamicResource BtnDisabledBgBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource BtnDisabledFgBrush}"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <!-- 刷新按钮 (悬浮时旋转 360 度交互) -->
        <Style x:Key="BtnRefresh" TargetType="Button">
            <Setter Property="Width" Value="36"/><Setter Property="Height" Value="36"/><Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/><Setter Property="BorderThickness" Value="0"/><Setter Property="FontSize" Value="16"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}" CornerRadius="8" x:Name="b">
                    <Border.RenderTransform>
                        <RotateTransform x:Name="rotate" Angle="0"/>
                    </Border.RenderTransform>
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="b" Property="Background" Value="{DynamicResource HoverBgBrush}"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="rotate" Storyboard.TargetProperty="Angle" To="360" Duration="0:0:0.6">
                                        <DoubleAnimation.EasingFunction>
                                            <QuadraticEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="rotate" Storyboard.TargetProperty="Angle" To="0" Duration="0:0:0.4"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <!-- 复选框 (打勾缩放淡入动效) -->
        <Style x:Key="AppCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/><Setter Property="FontSize" Value="12"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="CheckBox">
                <StackPanel Orientation="Horizontal">
                    <Border Width="18" Height="18" CornerRadius="5" Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1.5" x:Name="cb">
                        <TextBlock Text="✓" Foreground="White" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                   Opacity="0" x:Name="ck" RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <ScaleTransform ScaleX="0" ScaleY="0" x:Name="markScale"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Border>
                    <ContentPresenter VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="cb" Property="Background" Value="{DynamicResource AccentBrush}"/>
                        <Setter TargetName="cb" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="ck" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="markScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="markScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="ck" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="markScale" Storyboard.TargetProperty="ScaleX" To="0" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="markScale" Storyboard.TargetProperty="ScaleY" To="0" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <!-- 开关 Switch (平滑平移动画) -->
        <Style x:Key="SwitchToggle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="CheckBox">
                <Border Width="44" Height="24" CornerRadius="12" Background="{DynamicResource ToggleTrackBgBrush}"
                        BorderBrush="{DynamicResource ToggleTrackBorderBrush}" BorderThickness="1" x:Name="track">
                    <Ellipse Width="16" Height="16" Fill="{DynamicResource ToggleThumbBrush}" HorizontalAlignment="Left" Margin="3,0,3,0" x:Name="thumb" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <TranslateTransform X="0" x:Name="trans"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <Border.Effect>
                        <DropShadowEffect Color="#007AFF" BlurRadius="8" ShadowDepth="0" Opacity="0.08"/>
                    </Border.Effect>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="track" Property="Background" Value="{DynamicResource ToggleTrackCheckedBgBrush}"/>
                        <Setter TargetName="track" Property="BorderBrush" Value="{DynamicResource ToggleTrackCheckedBorderBrush}"/>
                        <Setter TargetName="thumb" Property="Fill" Value="White"/>
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="trans" Storyboard.TargetProperty="X" To="20" Duration="0:0:0.18">
                                        <DoubleAnimation.EasingFunction>
                                            <QuadraticEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="trans" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.18">
                                        <DoubleAnimation.EasingFunction>
                                            <QuadraticEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="track" Property="Opacity" Value="0.9"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="track" Property="Opacity" Value="0.45"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate></Setter.Value></Setter>
        </Style>

        <!-- 单选框 -->
        <Style x:Key="SettingsRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/><Setter Property="FontSize" Value="11"/><Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="RadioButton">
                <StackPanel Orientation="Horizontal">
                    <Border Width="16" Height="16" CornerRadius="8" Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" x:Name="rb">
                        <Ellipse Width="6" Height="6" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                 Opacity="0" x:Name="dot" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="0" ScaleY="0" x:Name="dotScale"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Border>
                    <ContentPresenter VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsChecked" Value="True">
                        <Setter TargetName="rb" Property="Background" Value="{DynamicResource AccentBrush}"/>
                        <Setter TargetName="rb" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="dot" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="dotScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="dotScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="dot" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="dotScale" Storyboard.TargetProperty="ScaleX" To="0" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="dotScale" Storyboard.TargetProperty="ScaleY" To="0" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
